{
  "manifest_version": 3,
  "name": "FOLIO Inn-Reach Tools",
  "version": "2.0.0",
  "description": "Inn-Reach paging slips and broken transaction management for FOLIO",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "cookies"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FOLIO Inn-Reach Tools"
  },
  "web_accessible_resources": [
    {
      "resources": ["modal.css"],
      "matches": ["*://*/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
